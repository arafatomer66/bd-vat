// Bangladesh VAT management — data model (NBR / SD&VAT Act 2012, Mushak regime).
// Multi-tenant: one Tenant == one VAT-registered company (one BIN).

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ACCOUNTANT
  VIEWER
}

enum PartyType {
  CUSTOMER
  SUPPLIER
  BOTH
}

enum TransactionKind {
  SALE
  PURCHASE
}

enum TransactionStatus {
  DRAFT
  ISSUED
  CANCELLED
}

enum AdjustmentKind {
  INCREASING // debit note — increases net payable
  DECREASING // credit note — decreases net payable
}

enum ReturnStatus {
  DRAFT
  FINALISED
  SUBMITTED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}

model Tenant {
  id                String   @id @default(cuid())
  name              String
  bin               String   @unique // 13-digit Business Identification Number
  tin               String? // 12-digit e-TIN
  // NBR jurisdiction
  commissionerate   String?
  division          String?
  circle            String?
  economicActivity  String? // primary economic activity / sector code
  address           String?
  createdAt         DateTime @default(now())

  users        User[]
  parties      Party[]
  products     Product[]
  transactions Transaction[]
  adjustments  Adjustment[]
  returns      VatReturn[]
  vdsCerts     VdsCertificate[]
  auditLogs    AuditLog[]
  memberships  Membership[]
  documents    MushakDocument[]
  coefficients Coefficient[]
  accounts     Account[]
  journalEntries JournalEntry[]
}

// Double-entry chart of accounts.
model Account {
  id        String      @id @default(cuid())
  tenantId  String
  tenant    Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  code      String // e.g. "1100"
  name      String
  type      AccountType
  createdAt DateTime    @default(now())

  lines JournalLine[]

  @@unique([tenantId, code])
  @@index([tenantId])
}

model JournalEntry {
  id         String        @id @default(cuid())
  tenantId   String
  tenant     Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  date       DateTime
  memo       String?
  sourceType String? // "transaction" | "manual"
  sourceId   String?
  createdAt  DateTime      @default(now())

  lines JournalLine[]

  @@index([tenantId, date])
}

model JournalLine {
  id        String       @id @default(cuid())
  entryId   String
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  accountId String
  account   Account      @relation(fields: [accountId], references: [id])
  debit     Decimal      @default(0) @db.Decimal(18, 2)
  credit    Decimal      @default(0) @db.Decimal(18, 2)

  @@index([entryId])
  @@index([accountId])
}

// Flexible record for the movement/record Mushak forms that share a shape:
//   6.4  contract (job) manufacturing
//   6.5  transfer of goods between own premises / branches
//   6.10 record of purchases & supplies above the prescribed threshold
model MushakDocument {
  id           String   @id @default(cuid())
  tenantId     String
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  form         String // "6.4" | "6.5" | "6.10"
  docNo        String?
  counterparty String?
  fromLocation String?
  toLocation   String?
  reason       String?
  issuedAt     DateTime
  value        Decimal  @default(0) @db.Decimal(18, 2)
  vat          Decimal  @default(0) @db.Decimal(18, 2)
  lines        String? // JSON array of { description, quantity, unitPrice }
  createdAt    DateTime @default(now())

  @@index([tenantId, form, issuedAt])
}

// Mushak 4.3 — input-output coefficient (price/coefficient) declaration for a
// manufactured output: how much of each input goes into one unit of output.
model Coefficient {
  id         String   @id @default(cuid())
  tenantId   String
  tenant     Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  productName String
  outputUnit String?
  inputs     String // JSON array of { name, quantity, unit, unitPrice }
  declaredAt DateTime @default(now())

  @@index([tenantId])
}

// Append-only audit trail of significant actions per tenant.
model AuditLog {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId    String?
  action    String // e.g. "transaction.create", "return.submit"
  entity    String? // entity type
  entityId  String?
  meta      String? // small JSON blob
  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
}

model User {
  id           String   @id @default(cuid())
  tenantId     String // home tenant
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email        String   @unique
  passwordHash String
  name         String?
  role         Role     @default(OWNER)
  createdAt    DateTime @default(now())

  memberships Membership[]

  @@index([tenantId])
}

// Lets one user access multiple companies (accounting-firm mode). The home tenant on
// User is an implicit membership; this table holds the additional ones with their role.
model Membership {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role      Role     @default(ACCOUNTANT)
  createdAt DateTime @default(now())

  @@unique([userId, tenantId])
  @@index([tenantId])
}

model Party {
  id        String    @id @default(cuid())
  tenantId  String
  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  type      PartyType @default(CUSTOMER)
  bin       String? // counterparty BIN (required for B2B input rebate)
  address   String?
  createdAt DateTime  @default(now())

  transactions Transaction[]
  adjustments  Adjustment[]

  @@index([tenantId])
}

model Product {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name      String
  unit      String? // pcs, kg, hour...
  hsCode    String? // HS code where applicable
  vatRate   Decimal  @default(0.15) @db.Decimal(5, 4)
  sdRate    Decimal  @default(0) @db.Decimal(5, 4)
  createdAt DateTime @default(now())

  @@index([tenantId])
}

model Transaction {
  id        String            @id @default(cuid())
  tenantId  String
  tenant    Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind      TransactionKind
  status    TransactionStatus @default(DRAFT)
  partyId   String?
  party     Party?            @relation(fields: [partyId], references: [id])
  // Mushak 6.3 invoice number for SALEs; supplier's invoice ref for PURCHASEs
  mushakNo  String?
  issuedAt  DateTime
  // Eligible for input-VAT rebate (PURCHASE only, when conditions are met)
  rebateEligible Boolean      @default(false)

  netTotal  Decimal @default(0) @db.Decimal(18, 2)
  sdTotal   Decimal @default(0) @db.Decimal(18, 2)
  vatTotal  Decimal @default(0) @db.Decimal(18, 2)
  grandTotal Decimal @default(0) @db.Decimal(18, 2)

  lines     TransactionLine[]
  vdsCerts  VdsCertificate[]
  createdAt DateTime @default(now())

  @@index([tenantId, kind, issuedAt])
}

model TransactionLine {
  id            String      @id @default(cuid())
  transactionId String
  transaction   Transaction @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  description   String
  quantity      Decimal     @db.Decimal(18, 4)
  unitPrice     Decimal     @db.Decimal(18, 4)
  vatRate       Decimal     @db.Decimal(5, 4)
  sdRate        Decimal     @default(0) @db.Decimal(5, 4)
  netValue      Decimal     @db.Decimal(18, 2)
  sdAmount      Decimal     @db.Decimal(18, 2)
  vatAmount     Decimal     @db.Decimal(18, 2)
  lineTotal     Decimal     @db.Decimal(18, 2)

  @@index([transactionId])
}

// Mushak 6.6 — VAT Deducted at Source certificate.
model VdsCertificate {
  id            String       @id @default(cuid())
  tenantId      String
  tenant        Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactionId String?
  transaction   Transaction? @relation(fields: [transactionId], references: [id])
  certificateNo String
  // true  => VAT withheld on OUR sales by a withholding entity (reduces our payable)
  // false => VAT WE withheld on a purchase (we deposit to treasury)
  withheldOnOurSales Boolean
  amount        Decimal      @db.Decimal(18, 2)
  issuedAt      DateTime

  @@index([tenantId])
}

// Mushak 6.7 (credit) / 6.8 (debit) and other increasing/decreasing adjustments.
model Adjustment {
  id        String         @id @default(cuid())
  tenantId  String
  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  kind      AdjustmentKind
  form      String? // "6.7" (credit note) | "6.8" (debit note) | null (generic)
  refNo     String? // note number
  reason    String?
  partyId   String?
  party     Party?         @relation(fields: [partyId], references: [id])
  amount    Decimal        @db.Decimal(18, 2) // VAT amount adjusted
  issuedAt  DateTime

  @@index([tenantId, issuedAt])
}

// Mushak 9.1 — monthly VAT return for one tax period.
model VatReturn {
  id         String       @id @default(cuid())
  tenantId   String
  tenant     Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  year       Int
  month      Int // 1-12
  status     ReturnStatus @default(DRAFT)

  outputVat            Decimal @default(0) @db.Decimal(18, 2)
  outputSd             Decimal @default(0) @db.Decimal(18, 2)
  inputVatRebate       Decimal @default(0) @db.Decimal(18, 2)
  vdsWithheldOnSales   Decimal @default(0) @db.Decimal(18, 2)
  increasingAdjustment Decimal @default(0) @db.Decimal(18, 2)
  decreasingAdjustment Decimal @default(0) @db.Decimal(18, 2)
  openingRebateBalance Decimal @default(0) @db.Decimal(18, 2)
  treasuryDeposits     Decimal @default(0) @db.Decimal(18, 2)
  netPayable           Decimal @default(0) @db.Decimal(18, 2)
  carryForward         Decimal @default(0) @db.Decimal(18, 2)

  // Treasury challan reconciliation (payment proof for the net payable).
  challanNo   String?
  challanDate DateTime?

  submittedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([tenantId, year, month])
}
